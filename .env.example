# ─────────────────────────────────────────────────────────────────────────────
# Unigather Website — Required Environment Variables
# Copy this file to .env.local and fill in the values.
# ALL variables marked REQUIRED must be set in Vercel for the site to work.
# ─────────────────────────────────────────────────────────────────────────────


# ── Firebase (Client SDK — public, prefixed with NEXT_PUBLIC_) ───────────────
# Get from Firebase Console → Project Settings → Your apps → Web app → SDK setup
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=


# ── Firebase Admin SDK (Server-side only — NEVER prefix with NEXT_PUBLIC_) ───
# Get from Firebase Console → Project Settings → Service accounts → Generate new private key
# REQUIRED — without these, ALL payment routes will crash at startup.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key including -----BEGIN PRIVATE KEY----- header.
# In Vercel, paste as-is (it handles newlines). In .env.local use literal \n.
FIREBASE_PRIVATE_KEY=


# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get from Razorpay Dashboard → Settings → API Keys

# Server-side key (same value as NEXT_PUBLIC_RAZORPAY_KEY_ID, but not public)
# REQUIRED — used by the create-order API route
RAZORPAY_KEY_ID=

# Public key for the browser checkout widget
# REQUIRED — must match RAZORPAY_KEY_ID
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Secret key — REQUIRED
RAZORPAY_KEY_SECRET=

# Webhook secret — get from Razorpay Dashboard → Webhooks → your endpoint secret
# Required to validate incoming webhook events from Razorpay
RAZORPAY_WEBHOOK_SECRET=

# Currency to use for payments (default: INR)
# RAZORPAY_CURRENCY=INR

# Payment expiry in minutes (default: 15)
# RAZORPAY_PAYMENT_TIMEOUT_MINUTES=15

# Whether Razorpay webhook should own booking confirmation (default: false)
# When true, verify-payment only records the payment; webhook creates the booking.
# USE_WEBHOOK_BOOKING_CONFIRMATION=false


# ── Email — Resend ────────────────────────────────────────────────────────────
# Get from https://resend.com → API Keys
# REQUIRED for booking confirmation emails
RESEND_API_KEY=

# Sender address (must be verified in your Resend account)
# EMAIL_FROM=Unigather <bookings@unigather.co.in>

# Set to "false" to disable emails entirely (useful for testing)
# EMAIL_AFTER_CONFIRMATION=true


# ── Internal API security ─────────────────────────────────────────────────────
# Used to sign internal server-to-server email requests.
# Falls back to RAZORPAY_KEY_SECRET if not set; set this for stricter isolation.
# INTERNAL_EMAIL_API_SECRET=


# ── Cloudinary (Image uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
